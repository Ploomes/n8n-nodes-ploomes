{
  "name": "n8n-nodes-ploomes",
  "version": "0.1.4",
  "description": "n8n community node for Ploomes CRM API",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ploomes",
    "crm",
    "odata"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Ploomes/n8n-nodes-ploomes",
  "author": {
    "name": "Ploomes",
    "url": "https://www.ploomes.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ploomes/n8n-nodes-ploomes.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json --ext .ts",
    "lintfix": "eslint nodes credentials package.json --ext .ts --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PloomesApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Ploomes/Ploomes.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
